# OBV hybrid verification — live AI provider configuration.
# Copy to .env (gitignored) or export in the server environment.
# The key is used server-side only and is never sent to the browser,
# logged, or committed. Without a key, OBV runs the deterministic demo
# verification (MOCK_DEFAULT) and the hero loop works fully.

# Anthropic API key enabling live multimodal visual assessment.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown).
# OBV_AI_MODEL=claude-haiku-4-5-20251001
# OBV_AI_TIMEOUT_MS=8000
# OBV_AI_BASE_URL=https://api.anthropic.com
