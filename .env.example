# OBV environment configuration — names only, never real values.
# Copy to .env (gitignored) for local use, or set these in your hosting
# platform's environment settings. Every variable is optional: with no
# configuration at all, OBV runs the full demo (deterministic fallback
# verification, in-app notifications, PDF reports if Chromium is present).

# ============================== REQUIRED ==============================
# (none — OBV boots and demos fully with zero configuration)
#
# PORT is provided by the hosting platform (Render sets it automatically;
# the Docker image defaults to 10000, local default is 3000).
# PORT=3000

# ========================= OPTIONAL — AI ==============================
# Anthropic API key enabling live multimodal visual assessment of
# evidence photos. Server-side only: never sent to the browser, never
# logged, never committed. Without it, verification uses the
# deterministic demo path (MOCK_DEFAULT) and everything still works.
ANTHROPIC_API_KEY=

# Overrides (defaults shown).
# OBV_AI_MODEL=claude-haiku-4-5-20251001
# OBV_AI_TIMEOUT_MS=8000
# OBV_AI_BASE_URL=https://api.anthropic.com

# ======================== OPTIONAL — TEAMS ============================
# Microsoft Teams incoming-webhook URL for governance notifications.
# Server-side only; never exposed client-side, never logged in full.
# Without it, OBV runs in demo notification mode (in-app feed only).
TEAMS_WEBHOOK_URL=

# Overrides (defaults shown).
# TEAMS_NOTIFICATION_TIMEOUT_MS=5000

# Public base URL of this OBV deployment; used for "Open in OBV" links
# on Teams cards. On Render this defaults to RENDER_EXTERNAL_URL, so you
# only need it on other hosts or behind a custom domain.
# OBV_PUBLIC_BASE_URL=https://obv-demo.onrender.com

# ==================== OPTIONAL — TEAMS CONVERSATION SYNC ==============
# Microsoft Graph app credentials enabling two-way coordination-message
# sync between bound OBV threads and Teams channels. Server-side only;
# never sent to the browser, never logged, never committed. Without
# them, sync shows "not configured" and everything else works fully.
# (Event notification cards use TEAMS_WEBHOOK_URL above — separate.)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Delegated send credential (SECRET): refresh token for the dedicated
# OBV service account (delegated ChannelMessage.Send). Application
# permissions cannot post channel messages operationally in real Graph.
# Obtain once with: node scripts/teams-delegated-auth.js
MICROSOFT_SEND_REFRESH_TOKEN=

# Outbound send mode: "delegated" (default, production) or "app-test"
# (contract-stub testing only — hard-blocked against real Graph).
# OBV_TEAMS_SEND_MODE=delegated

# Public HTTPS URL Microsoft Graph calls with change notifications
# (defaults to <OBV_PUBLIC_BASE_URL>/api/teams-sync/notifications).
# OBV_TEAMS_WEBHOOK_PUBLIC_URL=https://obv-demo.onrender.com/api/teams-sync/notifications

# Key letting an external scheduler call POST /api/teams-sync/maintain
# (subscription renewal) with the X-OBV-Maintenance-Key header.
# OBV_TEAMS_MAINTENANCE_KEY=

# Overrides (defaults shown; test suites point these at a local stub).
# OBV_TEAMS_SYNC_TIMEOUT_MS=8000
# OBV_GRAPH_BASE_URL=https://graph.microsoft.com
# OBV_GRAPH_LOGIN_URL=https://login.microsoftonline.com

# ==================== OPTIONAL — WHATSAPP FIELD BRIDGE ================
# WhatsApp Business Cloud API (Meta) credentials enabling the field
# coordination bridge: inbound field messages/media into OBV threads and
# policy-gated outbound coordination. Server-side only; never sent to
# the browser, never logged, never committed. Without them, WhatsApp
# shows "not configured" and everything else works fully.
# Setup guide: docs/WHATSAPP_REAL_SETUP.md
#
# WhatsApp COORDINATES ONLY — nothing arriving on this channel can
# create evidence, satisfy approvals, or release funds.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Value you choose; Meta echoes it during webhook verification.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta app secret used to validate X-Hub-Signature-256 on every webhook.
WHATSAPP_APP_SECRET=

# Overrides (defaults shown; the test suite points the base URL at a
# local contract stub — production leaves it at Meta's Graph endpoint).
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_SYNC_TIMEOUT_MS=8000
# OBV_WHATSAPP_API_BASE_URL=https://graph.facebook.com

# ======================= OPTIONAL — STORAGE ===========================
# Root directory for ALL runtime data: obv.db (SQLite), uploads/,
# worm/ (immutable evidence), reports/. Point this at a persistent
# volume mount (e.g. /var/data on a Render disk) to survive restarts.
# Default: ./data relative to the working directory (ephemeral in
# containers — a restart reseeds the demo).
# OBV_DATA_DIR=/var/data

# Relocate generated report PDFs separately from the rest of the data
# (rarely needed; default is <OBV_DATA_DIR>/reports).
# OBV_REPORT_STORAGE_PATH=/var/data/reports

# ====================== OPTIONAL — DEPLOYMENT =========================
# Simple deployment-level access protection. When set, every page and
# API (except /api/health) requires this code once per browser; the
# cookie stores only a hash of the code. Leave unset for an open demo.
# OBV_ACCESS_CODE=

# Where the PDF render child process resolves the playwright module.
# The Docker image sets this to /app/node_modules; the local dev
# environment default is /opt/node22/lib/node_modules.
# OBV_PLAYWRIGHT_NODE_PATH=/app/node_modules
