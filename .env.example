# OBV environment configuration — names only, never real values.
# Copy to .env (gitignored) for local use, or set these in your hosting
# platform's environment settings. Every variable is optional: with no
# configuration at all, OBV runs the full demo (deterministic fallback
# verification, in-app notifications, PDF reports if Chromium is present).

# ============================== REQUIRED ==============================
# (none — OBV boots and demos fully with zero configuration)
#
# PORT is provided by the hosting platform (Render sets it automatically;
# the Docker image defaults to 10000, local default is 3000).
# PORT=3000

# ========================= OPTIONAL — AI ==============================
# Anthropic API key enabling live multimodal visual assessment of
# evidence photos. Server-side only: never sent to the browser, never
# logged, never committed. Without it, verification uses the
# deterministic demo path (MOCK_DEFAULT) and everything still works.
ANTHROPIC_API_KEY=

# Overrides (defaults shown).
# OBV_AI_MODEL=claude-haiku-4-5-20251001
# OBV_AI_TIMEOUT_MS=8000
# OBV_AI_BASE_URL=https://api.anthropic.com

# ======================== OPTIONAL — TEAMS ============================
# Microsoft Teams incoming-webhook URL for governance notifications.
# Server-side only; never exposed client-side, never logged in full.
# Without it, OBV runs in demo notification mode (in-app feed only).
TEAMS_WEBHOOK_URL=

# Overrides (defaults shown).
# TEAMS_NOTIFICATION_TIMEOUT_MS=5000

# Public base URL of this OBV deployment; used for "Open in OBV" links
# on Teams cards. On Render this defaults to RENDER_EXTERNAL_URL, so you
# only need it on other hosts or behind a custom domain.
# OBV_PUBLIC_BASE_URL=https://obv-demo.onrender.com

# ======================= OPTIONAL — STORAGE ===========================
# Root directory for ALL runtime data: obv.db (SQLite), uploads/,
# worm/ (immutable evidence), reports/. Point this at a persistent
# volume mount (e.g. /var/data on a Render disk) to survive restarts.
# Default: ./data relative to the working directory (ephemeral in
# containers — a restart reseeds the demo).
# OBV_DATA_DIR=/var/data

# Relocate generated report PDFs separately from the rest of the data
# (rarely needed; default is <OBV_DATA_DIR>/reports).
# OBV_REPORT_STORAGE_PATH=/var/data/reports

# ====================== OPTIONAL — DEPLOYMENT =========================
# Simple deployment-level access protection. When set, every page and
# API (except /api/health) requires this code once per browser; the
# cookie stores only a hash of the code. Leave unset for an open demo.
# OBV_ACCESS_CODE=

# Where the PDF render child process resolves the playwright module.
# The Docker image sets this to /app/node_modules; the local dev
# environment default is /opt/node22/lib/node_modules.
# OBV_PLAYWRIGHT_NODE_PATH=/app/node_modules
